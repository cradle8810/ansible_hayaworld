services:
  ollama:
    image: ollama/ollama:0.30.7
    container_name: ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama:/root/.ollama
      - /home/hayato/Models:/root/Models:ro
      - /dev/hugepages:/dev/hugepages
    devices:
      - /dev/dri:/dev/dri
    environment:
      - OLLAMA_VULKAN=1
      - OLLAMA_ORIGINS="*"
      - OLLAMA_INTEL_GPU=1
      - OLLAMA_NUM_PARALLEL=1
      - OLLAMA_FLASH_ATTENTION=false
      - OLLAMA_IGPU_ENABLE=true
      - OLLAMA_KEEP_ALIVE="-1"
      - HUGETLB_MORECORE=yes
      - GLIBC_TUNABLES=glibc.malloc.hugetlb=1
      - ENABLE_WEB_SEARCH=true
      - WEB_SEARCH_ENGINE=searxng
      - SEARXNG_QUERY_URL="https://searxng.{{ searxng_base_url_domain }}/search?q=<query>&format=json"
    deploy:
      resources:
        limits:
          pids: 65535
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65535
        hard: 65535
    cap_add:
      - SYS_ADMIN
      - IPC_LOCK
    restart: unless-stopped

  tika:
    image: apache/tika:latest-full
    container_name: tika
    ports:
      - 9998:9998
    restart: unless-stopped

volumes:
  ollama:
