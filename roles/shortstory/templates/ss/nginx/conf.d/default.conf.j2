gzip on;
gzip_comp_level 7;
gzip_min_length 1024;
gzip_vary on;
gzip_proxied any;

server {
  listen 8080;
  server_name ss.hayaworld.home;

  charset UTF-8;

  root /usr/share/nginx/html;

  location / {
    autoindex on;
    autoindex_exact_size off;
    autoindex_localtime on;

    add_before_body /header.html;
  }
}
