conf-dir=/etc/dnsmasq.d,*.conf
no-resolv

domain={{ dnsmasq_domain }}
local={{ dnsmasq_local }}

cache-size={{ dnsmasq_dns_cache_size }}

resolv-file=/etc/dnsmasq.d/resolv.txt
addn-hosts=/etc/hayaworld_hosts

# IPv4 NGN Forwarding
server=/flets/123.107.190.7
server=/v4flets-east.jp/123.107.190.7
server=/speed.flets/123.107.190.7

#log-queries
log-facility={{ dnsmasq_logs_log_facility }}

{% for dns_server in outer_dns_servers.ipv4 %}
server={{ dns_server.addr }}#{{ dns_server.port }}
{% endfor %}

{% if dns_cname is defined %}
{% for item in dns_cname %}
cname={{ item.name }},{{ item.real }}
{% endfor %}
{% endif %}
