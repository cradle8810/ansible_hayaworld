services:
  pihole:
    hostname: "{{ common_hostinfo.shortname }}"
    container_name: pihole
    image: pihole/pihole:latest
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "80:80/tcp"
    environment:
      TZ: 'Asia/Tokyo'
      FTLCONF_webserver_api_password: '{{ pihole_http_cred }}'
      FTLCONF_dns_listeningMode: 'ALL'
      FTLCONF_dns_upstreams: '202.232.2.3;202.232.2.2'
    volumes:
      - './etc-pihole:/etc/pihole'
      - './etc-dnsmasq.d:/etc/dnsmasq.d'
    cap_add:
      - NET_ADMIN
      - SYS_TIME
      - SYS_NICE
    restart: unless-stopped
